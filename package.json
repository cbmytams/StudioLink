{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:test": "vite --mode test --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "npx tsc --noEmit && eslint .",
    "test": "VITE_APP_MODE=development VITE_BYPASS_CAPTCHA=false VITE_MOCK_EMAIL=false VITE_DISABLE_ANALYTICS=false VITE_MOCK_SUPABASE=false vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.include=src/lib/auth/handleAuthError.ts --coverage.include=src/lib/email/emailService.ts --coverage.include=src/lib/analytics/events.ts --coverage.include=src/lib/analytics/posthog.ts",
    "seed:test": "tsx scripts/seed_test_mode.ts",
    "check:test-mode": "tsx scripts/check_test_mode.ts",
    "invites:generate": "node --env-file=.env scripts/generate-invites.mjs",
    "uptimerobot:setup": "node scripts/setup-uptimerobot.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@sentry/react": "^10.46.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.23.24",
    "posthog-js": "^1.363.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "resend": "^6.9.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0",
    "vitest": "^2.1.8"
  }
}
